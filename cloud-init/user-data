#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  timezone: Europe/Madrid
  keyboard:
    layout: es
  
  network:
    network:
      version: 2
      ethernets:
        enp0s3:
          dhcp4: true
  
  identity:
    hostname: devpod-base
    password: "$6$Ra6OE/n.LieGCPCJ$JvvkaVPZzR8dekPs8frYvKym3w8jHq4C02CnqsF3BbBIAqT8LcUn8RMsEv5kBIZMBv.36dsePl.kelBzUlheI."
    username: dev
  
  ssh:
    install-server: true
    allow-pw: true
    authorized-keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIAOUbp01stanDcxPb2lrXtKsvMsneBVYrGtvfQh1NGYX djsurgeon83@gmail.com"
  
  storage:
    layout:
      name: direct
  
  packages: [sudo,curl,wget,vim,nano,git,htop,build-essential,python3,python3-pip,python3-venv,ca-certificates,gnupg,apt-transport-https,software-properties-common,docker.io,docker-compose-v2]
  
  late-commands:
    - curtin in-target -- sh -c "getent group docker || groupadd docker"
    - curtin in-target -- sh -c "usermod -aG docker dev || true"
    - curtin in-target -- sh -c "sed -i 's/^#Port.*/Port 22/' /etc/ssh/sshd_config || true"
    - curtin in-target -- sh -c "sed -i 's/^#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config || true"
    - curtin in-target -- sh -c "sed -i 's/^#PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config || true"
    - curtin in-target -- sh -c "fallocate -l 2048M /swapfile || true"
    - curtin in-target -- sh -c "chmod 600 /swapfile || true"
    - curtin in-target -- sh -c "mkswap /swapfile || true"
    - curtin in-target -- sh -c "grep -q swapfile /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab || true"

  user-data:
    package_upgrade: true
    runcmd:
      - usermod -aG docker dev

  shutdown: poweroff
